{
  "routes": [
    {
      "src": "/",
      "dest": "/api/app?route=app"
    },
    {
      "src": "/login",
      "dest": "/api/app?route=login-page"
    },
    {
      "src": "/api/(.*)",
      "dest": "/api/app?route=$1"
    },
    {
      "handle": "filesystem"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "functions": {
    "api/app.js": {
      "maxDuration": 60
    }
  }
}
