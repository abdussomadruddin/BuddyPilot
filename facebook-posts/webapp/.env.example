# Optional. Default is localhost only.
WEBAPP_HOST=127.0.0.1
WEBAPP_PORT=8787

# Recommended if you expose the app through LAN/tunnel.
WEBAPP_UPLOAD_PASSWORD=change-me

# Upload size limit in MB.
WEBAPP_MAX_UPLOAD_MB=200

# Defaults already point to ../facebook.env and ../post_to_facebook.sh.
# FACEBOOK_ENV_FILE=/absolute/path/to/facebook.env
# FACEBOOK_POST_SCRIPT=/absolute/path/to/post_to_facebook.sh
